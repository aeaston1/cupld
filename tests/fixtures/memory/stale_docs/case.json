{
  "cases": [
    {
      "name": "stale-transition-shape",
      "assertions": [
        {
          "type": "query_rows",
          "query": "MATCH (d:MarkdownDocument) RETURN d.`src.path`, d.`md.title`, d.`src.status` ORDER BY d.`src.path`",
          "expected": [
            {
              "columns": ["col_1", "col_2", "col_3"],
              "rows": [
                ["added.md", "Added", "current"],
                ["changed.md", "Changed", "current"],
                ["removed.md", "Removed", "missing"],
                ["stable.md", "Stable", "current"]
              ]
            }
          ]
        },
        {
          "type": "query_rows",
          "query": "MATCH (d:MarkdownDocument {`src.path`: 'removed.md'}) RETURN d.`src.path`, d.`src.status`",
          "expected": [
            {
              "columns": ["col_1", "col_2"],
              "rows": [
                ["removed.md", "missing"]
              ]
            }
          ]
        },
        {
          "type": "query_rows",
          "query": "MATCH (:MarkdownDocument {`src.path`: 'removed.md'})-[e:MD_LINKS_TO]->(:MarkdownDocument) RETURN count(e)",
          "expected": [
            {
              "columns": ["col_1"],
              "rows": [
                [0]
              ]
            }
          ]
        }
      ]
    }
  ]
}
