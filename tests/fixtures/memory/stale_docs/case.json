{
  "cases": [
    {
      "name": "stale-transition-shape",
      "assertions": [
        {
          "type": "query_rows",
          "query": "MATCH (d:MarkdownDocument) RETURN d.`src.path`, d.`md.title`, d.`src.status` ORDER BY d.`src.path`",
          "expected": [
            {
              "columns": ["col_1", "col_2", "col_3"],
              "rows": [
                ["added.md", "Added", "current"],
                ["changed.md", "Changed", "current"],
                ["stable.md", "Stable", "current"]
              ]
            }
          ]
        }
      ]
    }
  ]
}
